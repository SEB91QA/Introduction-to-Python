'''(Computer-Assisted Instruction: Difficulty Levels) '''
import random 


def correct():
    a = random.randrange(1, 4)

    if a == 1:
        print('Very good!')

    if a == 2:
        print('Nice work!')

    if a == 3:
        print('Keep up the good work!')


def incorrect():
    a = random.randrange(1, 4)

    if a == 1:
        print('No. Please try again.')

    if a == 2:
        print('Wrong. Try once more.')

    if a == 3:
        print('No. Keep trying.')


def computer_level1():
    a = random.randrange(0, 10)
    b = random.randrange(0, 10)

    return (a, b)


def computer_level2():
    a = random.randrange(0, 100)
    b = random.randrange(0, 100)

    return (a, b)


def difficulty(d: int):

    if d == 1:
        print("Welcome to multiplications of single-digit numers")

        contador = 1
        while contador <= 5:
            c = computer_level1()
            print(f"How much is {c[0]} times {c[1]}")
            r = int(input())

            while r != c[0]*c[1]:
                incorrect()
                r = int(input())

            correct()
            contador += 1

    if d == 2:
        print("Welcome to multiplications of tow-digit numbers")

        contador = 1
        while contador <= 5:
            c = computer_level2()
            print(f"How much is {c[0]} times {c[1]}")
            r = int(input())

            while r != c[0]*c[1]:
                incorrect()
                r = int(input())

            correct()
            contador += 1

    else:
        print("Difficulty out of range")

d = int(input("Please enter 1 for single-digit multiplication or 2 for two-digit multiplication"))

difficulty(d)



