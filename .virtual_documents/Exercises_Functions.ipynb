import random


def multiplication():
    num1 = random.randrange(1, 11)
    num2 = random.randrange(1, 11)

    print(f'The numbers are {num1} and {num2}')
    return num1, num2


def intelligence(num1, num2):

    return num1*(num2 + random.randrange(0, 2))
    # We need to add some balance. We can add or zero or 1


'''Product with intelligence'''

c = 'Yes'
v = 0
l = 0
e = 0
n = 0
while c == 'Yes':
    num1, num2 = multiplication()
    product = int(input('Please enter the product of numbers'))
    result_machine = intelligence(num1, num2)
    print(f"The machine's result is {result_machine}")

    if product == num1*num2 and result_machine != num1*num2:
        v += 1
        print('You win')

    elif product != num1*num2 and result_machine == num1*num2:
        l += 1
        print('You lose')

    elif product == num1*num2 and result_machine == num1*num2:
        e += 1
        print('Both win')

    else:
        print('Both answers are incorrect')

    n += 1
    c = input('Please enter Yes if want to keep playing')

print(f'You had {v} wins, {l} loses and {e} draws')


'''The tortoise and the hare'''
import random as random
import time
from IPython.display import clear_output


def tortoise():
    v = random.randrange(1, 11)
    if v >= 1 and v <= 5:
        #print("Fast plod")
        p = "Fast plod"
    if v >= 6 and v <= 7:
        #print("Slip")
        p = "Slip"
    if v >= 8 and v <= 10:
        #print("Slow pod")
        p = "Slow plod"

    return p


def hare():
    v = random.randrange(1, 11)
    if v >= 1 and v <= 2:
        #print("Sleep")
        p = 'Sleep'
    if v >= 3 and v <= 4:
        #print("Big Hop")
        p = 'Big Hop'
    if v == 5:
        #print("Big Slip")
        p = 'Big Slip'
    if v >= 6 and v <= 8:
        #print("Small Hop")
        p = 'Small Hop'
    if v >= 9 and v <= 10:
        #print("Small Slip")
        p = 'Small Slip'

    return p

# Include as a string values to show the positions


print("BANG !!!\nAND THEY'RE OFF\n")

tspacing = 1
hspacing = 1

#status = input('Empecemos el juego')
print(f"{'T':>{tspacing}}")
print(f"{'H':>{hspacing}}")

status = 'Empecemos'

while status:
    t = tortoise()
    h = hare()

    # ---- Tortoise Movements ---- #
    if t == "Fast plod":
        tspacing = tspacing + 3

    if t == "Slip":
        tspacing = tspacing - 6

    if t == "Slow pod":
        tspacing = tspacing + 1

    # ---- Hare Movements ---- #
    if h == "Sleep":
        hspacing = hspacing + 0

    if h == "Big Hop":
        hspacing = hspacing + 9

    if h == "Big Slip":
        hspacing = hspacing - 12

    if h == "Small Hop":
        hspacing = hspacing + 1

    if h == "Small Slip":
        hspacing = hspacing - 2

    if tspacing < 1:
        tspacing = 1

    if hspacing < 1:
        hspacing = 1

    clear_output(wait=True)

    if tspacing == 70 or hspacing == 70:
        if tspacing > hspacing:
            print("TORTOISE WINS!!! YAY!!")

        elif hspacing > tspacing:
            print("Hare wins")

        else:
            print("It's a tie")

        break

    if tspacing == hspacing:
        print(f"{'OUCH!':>{35}}")

    else:
        print(f"{'T':>{tspacing}}")
        print(f"{'H':>{hspacing}}")

    time.sleep(2)






