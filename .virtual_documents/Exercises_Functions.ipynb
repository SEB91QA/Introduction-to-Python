'''Computer-assisted instruction'''


def computer():
    a = random.randrange(0, 10)
    b = random.randrange(0, 10)

    return (a, b)


contador = 1
while contador <= 5:
    c = computer()
    print(f"How much is {c[0]} times {c[1]}")
    r = int(input())

    while r != c[0]*c[1]:
        print("No. Please try again.")
        r = int(input())

    print("Very good!")
    contador += 1

print("Thanks for playing")


